# Vercel: Project Settings → Environment Variables (Production, Preview, Development).
# Redeploy without build cache after adding or changing variables.

# Client (browser) — VITE_ prefix required for Vite
VITE_MYSPACE_SUPABASE_URL=https://your-project.supabase.co
VITE_MYSPACE_SUPABASE_ANON_KEY=your-anon-key

# Optional aliases (build can read these too)
MYSPACE_SUPABASE_URL=https://your-project.supabase.co
MYSPACE_SUPABASE_ANON_KEY=your-anon-key

# Server (admin API / server functions) — set these on Vercel too
MYSPACE_SUPABASE_URL=https://your-project.supabase.co
MYSPACE_SUPABASE_SERVICE_ROLE=your-service-role-key
MYSPACE_ADMIN_PASSWORD=your-admin-password

# Optional: client-side admin session key (must match MYSPACE_ADMIN_PASSWORD)
VITE_MYSPACE_ADMIN_PASSWORD=your-admin-password
